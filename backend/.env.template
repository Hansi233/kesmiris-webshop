# =============================================================================
# Kesmiris Medusa 2.0 Backend - Environment Variables Template
# =============================================================================
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# ---- App ----
NODE_ENV=development
MEDUSA_WORKER_MODE=shared       # shared | worker | server
PORT=9000
MEDUSA_BACKEND_URL=http://localhost:9000

# ---- Datenbank (Postgres 16) ----
DATABASE_URL=postgres://medusa:medusa@localhost:5433/kesmiris

# ---- Cache & Eventbus (Redis 7) ----
REDIS_URL=redis://localhost:6380

# ---- Secrets (lokal dev OK, prod MUSS gewechselt werden) ----
JWT_SECRET=change-me-in-prod
COOKIE_SECRET=change-me-in-prod

# ---- CORS ----
STORE_CORS=http://localhost:8000,http://localhost:3000
ADMIN_CORS=http://localhost:9000,http://localhost:7001
AUTH_CORS=http://localhost:8000,http://localhost:9000,http://localhost:7001

# ---- Stripe (Test-Mode für Dev) ----
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Resend (Email) ----
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@kesmiris.example
RESEND_ADMIN_NOTIFICATION_EMAIL=orga@midia-trading.com

# ---- Admin Dashboard ----
DISABLE_MEDUSA_ADMIN=false
