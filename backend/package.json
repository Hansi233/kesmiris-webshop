{
  "name": "kesmiris-backend",
  "version": "0.0.1",
  "description": "Kesmiris Webshop - Medusa 2.0 Backend (Klima + Heat-Pump Leads)",
  "author": "Kesmiris",
  "license": "MIT",
  "keywords": [
    "medusa",
    "kesmiris",
    "heatpump",
    "climate"
  ],
  "scripts": {
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "start": "medusa start",
    "dev": "medusa develop",
    "test:unit": "vitest run",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules vitest run",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.15.2",
    "@medusajs/cli": "2.15.2",
    "@medusajs/framework": "2.15.2",
    "@medusajs/medusa": "2.15.2",
    "@medusajs/payment-stripe": "2.15.2",
    "@mikro-orm/core": "6.4.3",
    "@mikro-orm/knex": "6.4.3",
    "@mikro-orm/migrations": "6.4.3",
    "@mikro-orm/postgresql": "6.4.3",
    "@swc-node/register": "^1.11.1",
    "awilix": "^8.0.1",
    "pg": "^8.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.0.1"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.15.2",
    "@swc/core": "1.5.7",
    "@swc/jest": "^0.2.36",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "yalc": "1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
